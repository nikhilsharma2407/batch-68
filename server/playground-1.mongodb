// decrement operation

db.users.findOneAndUpdate({ username: 'test', "cart.items.id": product1.id }, {
  // $ tell the index of the item in array to be updated
  $inc: { "cart.items.$.quantity": -1 }
}, { new: true });

db.users.findOneAndUpdate({ username: 'test' }, {
  $pull: { "cart.items": { id: 1 } }
}, { new: true })


